default:
  provider: aliyun
  text_model: qwen-turbo-1101
  image_model: qvq-max-2025-03-25
  summary_model: qwen-turbo-1101
  temperature: 0.7
  retry_count: 2
  timeout: 600
providers:
  aliyun:
    base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
    api_key_env: QWEN_API_KEY
    extra_headers: {}
    models:
    - qwen-max
    - qwen-max-latest
    - qwen-max-2025-01-25
    - qwen-plus-latest
    - qwen-plus-2025-07-28
    - qwen-turbo
    - qwen-turbo-latest
    - qwen-turbo-1101
    - qwen3.5-plus
    - qwen3-max-2025-09-23
    - qvq-plus
    - qwen3-vl-plus-2025-09-23
    - qwen-vl-plus
    - qwen-vl-plus-latest
    - qwen-long
    - qwen-long-latest
    - qwen-coder-plus
    - qwen-coder-plus-latest
    - deepseek-r1
    - kimi-k2.5
    - qwen-flash
    - qwen-flash-2025-07-28
    endpoints:
      cn: https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
      intl: https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions
      finance: https://dashscope-finance.aliyuncs.com/compatible-mode/v1/chat/completions
  openrouter:
    base_url: https://openrouter.ai/api/v1
    api_key_env: OPENROUTER_API_KEY
    extra_headers:
      HTTP-Referer: https://github.com/crewai-mas-demo
      X-Title: crewai-mas-demo
    models:
    - openai/gpt-4o
    - openai/gpt-4.1
    - openai/gpt-4.1-mini
    - openai/gpt-4.1-nano
    - anthropic/claude-sonnet-4-20250514
    - anthropic/claude-3.5-haiku
    - google/gemini-2.5-flash
    - google/gemini-2.5-pro
    - deepseek/deepseek-chat
    - deepseek/deepseek-r1-0528
    - meta-llama/llama-3.3-70b-instruct
    - qwen/qwen3-235b-a22b
models:
  assistant:
    model: qwen-turbo-1101
    temperature: 0.7
  lightweight:
    model: qwen-turbo-1101
    temperature: 0.3
  vision:
    model: qvq-max-2025-03-25
    temperature: 0.7
  coder:
    model: qwen-coder-turbo-0919
    temperature: 0.3
  long_context:
    model: qwen-long
    temperature: 0.7
allowed_models:
- qwen-turbo-1101
- llama-4-maverick-17b-128e-instruct
- qwen-max-latest
- qwen-max-2025-01-25
- qwen-plus-latest
- qwen-turbo
- qwen-turbo-latest
- qwen3.5-plus
- qwen3-max-2025-09-23
- qvq-plus
- qwen3-vl-plus-2025-09-23
- qwen-vl-plus
- qwen-vl-plus-latest
- qwen-long
- qwen-long-latest
- qwen-coder-plus
- qwen-coder-plus-latest
- deepseek-r1
- kimi-k2.5
- qwen-flash
- qwen3.6-plus
- qwen-flash-2025-07-28
- qvq-max-2025-03-25
- qwen3-vl-235b-a22b-thinking
- qwen-coder-turbo-0919
- qwen-vl-plus-2025-05-07
- deepseek-r1-distill-qwen-7b
- glm-5
- qwen3.5-35b-a3b
- gui-plus
- tongyi-xiaomi-analysis-flash
- MiniMax-M2.5
- qwq-plus-latest
- Moonshot-Kimi-K2-Instruct
endpoints:
  cn: https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
  intl: https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions
  finance: https://dashscope-finance.aliyuncs.com/compatible-mode/v1/chat/completions
